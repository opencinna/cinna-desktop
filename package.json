{
  "name": "cinna-desktop",
  "version": "0.2.3",
  "description": "Desktop client for remote agents (MCP, A2A, OpenCinna)",
  "author": "Evgenii Leksunin <evgeny-l@opencinna.io>",
  "homepage": "https://opencinna.io",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:mac:unsigned": "electron-vite build && electron-builder --mac -c.mac.identity=null -c.mac.notarize=false",
    "notarize:dmgs": "for f in dist/cinna-desktop-*.dmg; do echo \"--- $f ---\" && xcrun notarytool submit \"$f\" --apple-id \"$APPLE_ID\" --team-id \"$APPLE_TEAM_ID\" --password \"$APPLE_APP_SPECIFIC_PASSWORD\" --wait && xcrun stapler staple \"$f\"; done",
    "release:mac": "electron-vite build && electron-builder --mac --publish always",
    "release:linux": "electron-vite build && electron-builder --linux --publish always",
    "release:all": "electron-vite build && electron-builder --mac --linux --publish always",
    "start": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@anthropic-ai/sdk": "^0.89.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@scure/bip39": "^2.2.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.99.0",
    "@types/libsodium-wrappers": "^0.7.14",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "electron-updater": "^6.8.3",
    "libsodium-wrappers": "^0.8.4",
    "libsodium-wrappers-sumo": "^0.8.4",
    "lucide-react": "^0.511.0",
    "nanoid": "^5.1.7",
    "officeparser": "^7.0.3",
    "openai": "^6.34.0",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/postcss": "^4.1.4",
    "@types/better-sqlite3": "^7.6.0",
    "@types/libsodium-wrappers-sumo": "^0.7.8",
    "@types/node": "^22.19.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "vite": "^7.2.6",
    "vitest": "^3.2.6"
  }
}
